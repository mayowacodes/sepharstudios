/* Based on https://github.com/tsconfig/bases/blob/501da2bcd640cf95c95805783e1012b992338f28/bases/node22.json */
{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "node16",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "outDir": "dist",
    "types": ["node", "hardhat", "@nomicfoundation/hardhat-viem"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "contracts/**/*",
    "scripts/**/*",
    "test/**/*",
    "ignition/**/*",
    "hardhat.config.ts",
    "hardhat-viem.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "artifacts",
    "cache",
    "typechain-types",
    "**/.svelte*",
    "**/*svelte*"
  ]
}
