{
  "name": "@studiochain/contracts",
  "version": "1.0.0",
  "description": "StudioChain tokenomics smart contracts",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "hardhat node",
    "build": "hardhat compile",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "verify:amoy": "hardhat verify --network amoy",
    "verify:polygon": "hardhat verify --network polygon",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "typechain": "hardhat typechain",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@types/node": "^22.18.6",
    "dotenv": "^17.2.2",
    "ethers": "^6.15.0",
    "hardhat": "^3.0.6",
    "solhint": "^4.0.0",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "~5.2.0"
  },
  "dependencies": {
    "@chainlink/contracts": "^0.6.1"
  },
  "keywords": [
    "studiochain",
    "tokenomics",
    "nft",
    "defi",
    "smart-contracts",
    "ethereum",
    "polygon"
  ],
  "author": "StudioChain Team",
  "license": "MIT",
  "directories": {
    "test": "test"
  }
}
