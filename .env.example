# ================================
# Sephar Studios - Environment Variables
# ================================

# ----------------
# Server Config
# ----------------
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
ORIGIN=https://sepharstudios.com
BODY_SIZE_LIMIT=10485760

# ----------------
# Database (PostgreSQL)
# ----------------
DATABASE_URL=postgresql://username:password@host:port/database

# ----------------
# Authentication (Better Auth)
# ----------------
BETTER_AUTH_SECRET=your_32_character_or_longer_secret_key_here
BETTER_AUTH_URL=https://sepharstudios.com
BETTER_API_URL=https://sepharstudios.com/api/auth
PUBLIC_BETTER_AUTH_URL=https://sepharstudios.com

# ----------------
# OAuth Providers
# ----------------
# Google OAuth (Get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
REDIRECT_URI=https://sepharstudios.com/api/auth/callback/google

# Apple OAuth (Optional)
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# ----------------
# Storage (MinIO)
# ----------------
MINIO_ROOT_USER=your_minio_admin_username
MINIO_ROOT_PASSWORD=your_strong_minio_password_here
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=sephar-uploads
MINIO_PUBLIC_URL=https://s3.sepharstudios.com

# ----------------
# Web3 / Blockchain
# ----------------
# WalletConnect (Get from https://cloud.walletconnect.com/)
PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Smart Contract Addresses - Polygon Mainnet
PUBLIC_STC_TOKEN_POLYGON=0x
PUBLIC_SUBSCRIPTION_NFT_POLYGON=0x
PUBLIC_CREATOR_PAYMENTS_POLYGON=0x
PUBLIC_TOKEN_AMM_POLYGON=0x

# Smart Contract Addresses - Mumbai Testnet
PUBLIC_STC_TOKEN_MUMBAI=0x
PUBLIC_SUBSCRIPTION_NFT_MUMBAI=0x
PUBLIC_CREATOR_PAYMENTS_MUMBAI=0x
PUBLIC_TOKEN_AMM_MUMBAI=0x

# RPC URLs (Optional - defaults to public RPCs)
POLYGON_RPC_URL=https://polygon-rpc.com
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# ----------------
# Email / Webhooks
# ----------------
# Email Webhook (Resend, SendGrid, Mailgun, etc.)
EMAIL_WEBHOOK=https://your-email-service.com/webhook

# SMTP Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@sepharstudios.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Sephar Studios <noreply@sepharstudios.com>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@sepharstudios.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Sephar Studios <noreply@sepharstudios.com>

# ----------------
# Analytics (Optional)
# ----------------
PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
SENTRY_DSN=https://your-sentry-dsn.com
PUBLIC_POSTHOG_KEY=your_posthog_key
PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ----------------
# AI/Content Moderation (Optional)
# ----------------
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key



# WalletConnect (you'll get this next)
PUBLIC_WALLETCONNECT_PROJECT_ID=bbcddcc5afbf6cd4b9daface6c2aa284

# Alchemy RPC URLs
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/jDZ151u9mGIroWRG3tE_9
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/jDZ151u9mGIroWRG3tE_9

# Smart Contract Addresses (leave empty for now)
PUBLIC_STC_TOKEN_AMOY=0x
PUBLIC_SUBSCRIPTION_NFT_AMOY=0x
PUBLIC_CREATOR_PAYMENTS_AMOY=0x
PUBLIC_TOKEN_AMM_AMOY=0x

PUBLIC_STC_TOKEN_POLYGON=0x
PUBLIC_SUBSCRIPTION_NFT_POLYGON=0x
PUBLIC_CREATOR_PAYMENTS_POLYGON=0x
PUBLIC_TOKEN_AMM_POLYGON=0x