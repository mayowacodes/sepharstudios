{
	"name": "sepharstudios",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/web3",
		"packages/shared"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"build:web": "turbo run build --filter=web",
		"dev:web": "turbo run dev --filter=web",
		"dev:contracts": "turbo run dev --filter=contracts"
	},
	"devDependencies": {
		"turbo": "latest"
	}
}
